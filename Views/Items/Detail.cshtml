@model ItemDetailDto
@{
    ViewData["Title"] = Model.Name;
    var canEdit = ViewBag.CanEdit == true;
    var canViewSensitive = ViewBag.CanViewSensitive == true;
}

<div class="detail-title-row">
    <div>
        <h1>@Model.Name</h1>
        <div class="page-subtitle">
            @if (!string.IsNullOrEmpty(Model.CategoryName)) { <text>@Model.CategoryName · </text> }
            @if (canViewSensitive && !string.IsNullOrEmpty(Model.LocationName)) { <text>@Model.LocationName@(Model.LocationRoom is not null ? $" ({Model.LocationRoom})" : "")</text> }
        </div>
    </div>
    <div class="detail-actions">
        <span class="status-pill detail-status @Model.Status">@(string.IsNullOrWhiteSpace(Model.CustomStatus) ? Model.Status.ToDisplayName() : Model.CustomStatus)</span>
        @if (canEdit) { <a class="btn" asp-action="Duplicate" asp-route-id="@Model.Id"><i data-lucide="copy"></i> Duplicate as template</a> <a class="btn" asp-action="Edit" asp-route-id="@Model.Id"><i data-lucide="pencil"></i> Edit</a> }
        @if (canEdit)
        {
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" data-confirm="Permanently delete '@Model.Name'?">
                @Html.AntiForgeryToken()
                <button class="btn btn-danger" type="submit"><i data-lucide="trash-2"></i> Delete</button>
            </form>
        }
    </div>
</div>

<div class="detail-layout">
    <div>
        <div class="detail-image">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Name" />
            }
            else
            {
                <i data-lucide="image"></i>
            }
        </div>

        @if (Model.Tags.Any())
        {
            <div class="tag-row" style="margin-top:12px">
                @foreach (var t in Model.Tags)
                {
                    <span class="tag-chip" style="@(t.Colour is not null ? $"border-color:{t.Colour};color:{t.Colour}" : "")">@t.Name</span>
                }
            </div>
        }



        <div class="info-card">
            <h3>Additional pictures</h3>
            @if (Model.Photos.Any())
            {
                <div class="photo-grid">
                    @foreach (var photo in Model.Photos)
                    {
                        <div class="photo-tile">
                            <img src="@photo.ImagePath" alt="Additional photo for @Model.Name" />
                            @if (canEdit)
                            {
                                <form method="post" asp-action="DeletePhoto" data-confirm="Remove this photo?">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@photo.Id" />
                                    <input type="hidden" name="itemId" value="@Model.Id" />
                                    <button class="btn btn-danger btn-sm" type="submit">Delete</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="muted">No additional pictures yet.</p>
            }
            @if (canEdit)
            {
                <form method="post" asp-action="AddPhotos" enctype="multipart/form-data" class="form-grid compact-form-grid" style="margin-top:12px">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="field full"><label>Add pictures</label><input type="file" name="photos" multiple accept=".jpg,.jpeg,.png,.webp" /></div>
                    <div class="full"><button class="btn btn-primary" type="submit"><i data-lucide="images"></i> Upload pictures</button></div>
                </form>
            }
        </div>

        <div class="info-card" style="margin-top:16px">
            <h3>Identification</h3>
            <div class="info-row"><span class="label">Manufacturer</span><span class="value">@(Model.Manufacturer ?? "—")</span></div>
            <div class="info-row"><span class="label">Brand / range</span><span class="value">@(Model.Brand ?? "—")</span></div>
            <div class="info-row"><span class="label">Model</span><span class="value">@(Model.Model ?? "—")</span></div>
            <div class="info-row"><span class="label">Serial Number</span><span class="value">@(Model.SerialNumber ?? "—")</span></div>
            <div class="info-row"><span class="label">Memory / capacity</span><span class="value">@(Model.Memory ?? "—")</span></div>
            <div class="info-row"><span class="label">Owner</span><span class="value">@(Model.Owner ?? "—")</span></div>
            <div class="info-row"><span class="label">Year</span><span class="value">@(Model.ReleaseYear?.ToString() ?? "—")</span></div>
            <div class="info-row"><span class="label">Barcode</span><span class="value">@(Model.Barcode ?? "—")</span></div>
            <div class="info-row"><span class="label">Quantity</span><span class="value">@(Model.Quantity ?? 1)</span></div>
            <div class="info-row"><span class="label">Type / section</span><span class="value">@(Model.ItemTypeName ?? "—")</span></div>
            <div class="info-row"><span class="label">Platform</span><span class="value">@(Model.PlatformName ?? "—")</span></div>
            <div class="info-row"><span class="label">Condition</span><span class="value">@Model.Condition.ToDisplayName()</span></div>
        </div>

        <div class="info-card">
            <h3>Collection Details</h3>
            <div class="info-row"><span class="label">Case type</span><span class="value">@(Model.CaseType ?? "—")</span></div>
            <div class="info-row"><span class="label">Format</span><span class="value">@(Model.MediaFormat ?? "—")</span></div>
            <div class="info-row"><span class="label">Instruction / manual</span><span class="value">@(Model.Instruction ?? "—")</span></div>
            <div class="info-row"><span class="label">Boxed</span><span class="value">@(Model.Boxed.HasValue ? (Model.Boxed.Value ? "Yes" : "No") : "—")</span></div>
            <div class="info-row"><span class="label">For sale</span><span class="value">@(Model.Sell.HasValue ? (Model.Sell.Value ? "Yes" : "No") : "—")</span></div>
            <div class="info-row"><span class="label">Tested</span><span class="value">@(Model.Tested ?? "—")</span></div>
        </div>

        <div class="info-card">
            <h3>Financial</h3>
            <div class="info-row"><span class="label">Purchase Price</span><span class="value">@(Model.PurchasePrice.HasValue ? $"£{Model.PurchasePrice:N2}" : "—")</span></div>
            <div class="info-row"><span class="label">Current Value</span><span class="value">@(Model.CurrentValue.HasValue ? $"£{Model.CurrentValue:N2}" : "—")</span></div>
            <div class="info-row"><span class="label">Purchase Date</span><span class="value">@(Model.PurchaseDate?.ToString("dd MMM yyyy") ?? "—")</span></div>
            <div class="info-row"><span class="label">Purchased From</span><span class="value">@(Model.PurchasedFrom ?? "—")</span></div>
            <div class="info-row"><span class="label">Insured</span><span class="value">@(Model.IsInsured ? $"Yes ({Model.InsurancePolicy})" : "No")</span></div>
        </div>

        <div class="info-card">
            <h3>Warranty</h3>
            <div class="info-row"><span class="label">Info</span><span class="value">@(Model.WarrantyInfo ?? "—")</span></div>
            <div class="info-row"><span class="label">Expires</span><span class="value">@(Model.WarrantyExpiry?.ToString("dd MMM yyyy") ?? "—")</span></div>
            @if (!string.IsNullOrEmpty(Model.ManualUrl))
            {
                <div class="info-row"><span class="label">Manual</span><span class="value"><a href="@Model.ManualUrl" target="_blank" style="color:var(--accent)">Open ↗</a></span></div>
            }
        </div>
    </div>

    <div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="info-card">
                <h3>Description</h3>
                <p style="margin:0">@Model.Description</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="info-card">
                <h3>Notes</h3>
                <p style="margin:0">@Model.Notes</p>
            </div>
        }

        <div class="info-card">
            <h3>Loan Records</h3>
            @foreach (var l in Model.LoanRecords)
            {
                <div class="log-item">
                    <div class="log-title">Loaned to @l.LoanedTo @(l.IsReturned ? "(returned)" : "")</div>
                    <div class="log-meta">
                        @l.LoanedOn.ToString("dd MMM yyyy")
                        @(l.DueBack.HasValue ? $" · Due back {l.DueBack:dd MMM yyyy}" : "")
                        @(l.ContactInfo is not null ? $" · {l.ContactInfo}" : "")
                    </div>
                    @if (canEdit && !l.IsReturned)
                    {
                        <form method="post" asp-action="ReturnLoan" style="margin-top:6px">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="loanId" value="@l.Id" />
                            <input type="hidden" name="itemId" value="@Model.Id" />
                            <button class="btn btn-sm" type="submit"><i data-lucide="undo-2"></i> Mark returned</button>
                        </form>
                    }
                </div>
            }
            @if (!Model.LoanRecords.Any())
            {
                <p class="muted" style="margin:0 0 12px">No loan history.</p>
            }
            @if (canEdit)
            {
            <details>
                <summary class="btn btn-sm" style="display:inline-flex;cursor:pointer">+ Loan this item</summary>
                <form method="post" asp-action="Loan" class="form-grid" style="margin-top:12px">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ItemId" value="@Model.Id" />
                    <div class="field"><label>Loaned to</label><input name="LoanedTo" required /></div>
                    <div class="field"><label>Contact info</label><input name="ContactInfo" /></div>
                    <div class="field"><label>Due back</label><input type="date" name="DueBack" /></div>
                    <div class="field full"><label>Notes</label><textarea name="Notes"></textarea></div>
                    <div class="full"><button class="btn btn-primary" type="submit"><i data-lucide="send"></i> Save loan</button></div>
                </form>
            </details>
            }
        </div>

        <div class="info-card">
            <h3>Maintenance Log</h3>
            @foreach (var m in Model.MaintenanceLogs)
            {
                <div class="log-item">
                    <div class="log-title">@m.Description @(m.Cost.HasValue ? $"· £{m.Cost:N2}" : "")</div>
                    <div class="log-meta">
                        @m.Date.ToString("dd MMM yyyy")
                        @(m.NextDueDate.HasValue ? $" · Next due {m.NextDueDate:dd MMM yyyy}" : "")
                        @(m.PerformedBy is not null ? $" · by {m.PerformedBy}" : "")
                    </div>
                </div>
            }
            @if (!Model.MaintenanceLogs.Any())
            {
                <p class="muted" style="margin:0 0 12px">No maintenance history.</p>
            }
            @if (canEdit)
            {
            <details>
                <summary class="btn btn-sm" style="display:inline-flex;cursor:pointer">+ Log maintenance</summary>
                <form method="post" asp-action="AddMaintenance" class="form-grid" style="margin-top:12px">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ItemId" value="@Model.Id" />
                    <div class="field full"><label>Description</label><input name="Description" required /></div>
                    <div class="field"><label>Cost</label><input type="number" step="0.01" name="Cost" /></div>
                    <div class="field"><label>Date</label><input type="date" name="Date" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
                    <div class="field"><label>Next due date</label><input type="date" name="NextDueDate" /></div>
                    <div class="field"><label>Performed by</label><input name="PerformedBy" /></div>
                    <div class="full"><button class="btn btn-primary" type="submit"><i data-lucide="send"></i> Save log</button></div>
                </form>
            </details>
            }
        </div>

        <div class="info-card">
            <h3>Record Info</h3>
            <div class="info-row"><span class="label">Added</span><span class="value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</span></div>
            <div class="info-row"><span class="label">Last Updated</span><span class="value">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</span></div>
        </div>
    </div>
</div>
