@model CreateItemDto
@{
    ViewData["Title"] = "Add Item";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Item</h1>
        <div class="page-subtitle">Add a new belonging to your vault</div>
    </div>
    <a class="btn" asp-action="Index"><i data-lucide="arrow-left"></i> Back</a>
</div>

<form method="post" enctype="multipart/form-data" class="form-card">
    @Html.AntiForgeryToken()
    <partial name="_Form" model="Model" />
    <div class="form-actions">
        <button class="btn btn-primary" type="submit"><i data-lucide="check"></i> Save Item</button>
        <a class="btn" asp-action="Index">Cancel</a>
    </div>
</form>
