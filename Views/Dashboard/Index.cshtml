@model FinanceManagerAspNet.Models.DashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard"; var gb = CultureInfo.GetCultureInfo("en-GB"); var canEdit = User.Identity?.IsAuthenticated == true; var currentUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
}

<section class="hero card">
    <a class="arrow" asp-route-year="@Model.PreviousMonth.Year" asp-route-month="@Model.PreviousMonth.Month">‹</a>
    <div><p class="eyebrow">Viewing</p><h1>@Model.MonthStart.ToString("MMMM yyyy")</h1><p class="muted">Target: save @Model.MonthlySavingTarget.ToString("C0", gb) this month</p></div>
    <a class="arrow" asp-route-year="@Model.NextMonth.Year" asp-route-month="@Model.NextMonth.Month">›</a>
</section>

@if (TempData["CarryMessage"] != null)
{
    <section class="card" style="border-left:4px solid #2b8a3e;padding:12px;margin:12px 0;background:#eef9f0;"><strong>@TempData["CarryMessage"]</strong></section>
}

<section class="grid cards-4">
    <article class="card"><p class="eyebrow">Month result</p><h2 class="@(Model.IsAhead ? "good" : "bad")">@(Model.IsAhead ? "+" : "-")@Model.CarryOverAmount.ToString("C", gb)</h2><p>@(Model.IsAhead ? "Carrying forward as excess" : "Shortfall / debt carried forward")</p></article>
    <article class="card"><p class="eyebrow">Global goal</p><h2>@Model.TotalGoalBalance.ToString("C", gb)</h2><p>@Model.GlobalGoalRemaining.ToString("C", gb) left to £20k</p></article>
    <article class="card"><p class="eyebrow">With interest by @Model.TargetDate.ToString("MMM yyyy")</p><h2>@Model.ProjectedWithInterestByGoalDate.ToString("C", gb)</h2><p>Includes visible goal accounts + @Model.ProjectedSalarySavingsByGoalDate.ToString("C", gb) planned salary savings. Interest estimate: @Model.ProjectedInterestByGoalDate.ToString("C", gb)</p></article>
    <article class="card"><p class="eyebrow">Estimated time</p><h2>@(Model.MonthsToGoalAtCurrentPace < 0 ? "N/A" : Model.MonthsToGoalAtCurrentPace + " months")</h2><p>Based on current month pace</p></article>
</section>

@if (canEdit)
{
<section class="card">
    <form asp-action="SaveIncome" method="post" class="inline-form">
        <input type="hidden" name="year" value="@Model.Year" /><input type="hidden" name="month" value="@Model.Month" />
        <label>Money in this month <input name="amount" type="number" step="0.01" value="@Model.MonthlyIncome" /></label>
        <label>Sick days <input name="sickDays" type="number" value="@Model.SickDays" /></label>
        <button>Save income</button>
    </form>
</section>
}

<section class="grid cards-4 totals">
    <div class="card"><span>Bills</span><strong>@Model.BillsTotal.ToString("C", gb)</strong></div>
    <div class="card"><span>Extra expenses</span><strong>@Model.ExpensesTotal.ToString("C", gb)</strong></div>
    <div class="card"><span>Investments</span><strong>@Model.InvestmentsTotal.ToString("C", gb)</strong></div>
    <div class="card"><span>Remaining fund</span><strong>@Model.RemainingFund.ToString("C", gb)</strong></div>
</section>

<section class="card actions">
    @if (canEdit)
    {
        <button type="button" class="primary" data-open="addPaymentModal">Add payment / bill</button>
        <button type="button" class="primary" data-open="carryModal">Carry items into next month</button>
        <button type="button" data-open="accountModal">Update ISA / pots / hidden interest</button>
    }
    else
    {
        <a class="button primary" asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@currentUrl">Login to edit</a>
    }
    <a class="button" asp-controller="Statistics" asp-action="Index">Open statistics</a>
</section>

@foreach (var group in new[] { ("Bills", Model.Bills), ("Extra Expenses", Model.Expenses), ("Investments", Model.Investments), ("Savings", Model.Savings) })
{
    <section class="card table-card">
        <h2>@group.Item1</h2><div class="table-wrap">
        <table>
            <thead><tr><th>Name</th><th>Amount</th><th>Date</th><th>Category</th><th>Progress</th><th>Notes</th>@if (canEdit) { <th>Actions</th> }</tr></thead>
            <tbody>
                @foreach (var r in group.Item2)
                {
                    <tr>
                        <td>@r.Name</td>
                        <td>@r.Amount.ToString("C", gb)</td>
                        <td>@r.Date.ToString("dd MMM")</td>
                        <td>@r.Category</td>
                        <td>
                            @if (r.ProgressPercent.HasValue)
                            {
                                <div class="progress"><div class="progress-bar" role="progressbar" style="width:@r.ProgressPercent%">@r.ProgressPercent%</div></div>
                                <small class="muted">Ends @r.EndDate?.ToString("dd MMM yyyy", gb) — @r.MonthsRemaining months left</small>
                            }
                            else
                            {

                                <span class="muted">No length set</span>
                            }
                        </td>
                        <td>@r.Notes</td>
                        @if (canEdit) { <td><a class="button" asp-action="EditPayment" asp-route-source="@r.Source" asp-route-id="@r.Id" asp-route-year="@Model.Year" asp-route-month="@Model.Month">Edit</a></td> }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
}

<section class="card"><h2>Last updated</h2><div class="chips">@foreach(var item in Model.LastModified){
    <span>@item.KeyName: @(item.UpdatedAt?.ToString("dd MMM yyyy HH:mm") ?? "not recorded")</span>
}
</div></section>

@if (canEdit)
{
<div class="modal" id="addPaymentModal"><div class="modal-panel"><button class="x" data-close>×</button><h2>Add to dashboard</h2><form asp-action="AddPayment" method="post" class="account-form"><input type="hidden" name="year" value="@Model.Year" /><input type="hidden" name="month" value="@Model.Month" /><label>Section<select name="source"><option value="bills">Bills</option><option value="extra_expenses">Extra expenses</option><option value="investments">Investments</option><option value="savings">Savings</option></select></label><label>Name<input name="name" placeholder="e.g. Mortgage, ISA, Car repair" required /></label><label>Amount<input name="amount" type="number" step="0.01" placeholder="0.00" required /></label><label>Date<input name="date" type="date" value="@Model.MonthStart.ToString("yyyy-MM-dd")" required /></label><label>Category<input name="category" placeholder="Optional" /></label><label>Type<input name="type" placeholder="Optional" /></label><label>Length in months<input name="length" type="number" min="1" step="1" placeholder="Example: 12, 36, 420" /></label><label>Notes<input name="notes" placeholder="Optional notes" /></label><button class="primary">Add item</button></form><p class="muted">This writes directly into your existing SQL tables using the same columns as the old app.</p></div></div>

<div class="modal" id="carryModal"><div class="modal-panel"><button class="x" data-close>×</button><h2>Carry into @Model.NextMonth.ToString("MMMM yyyy")</h2><form asp-action="CarryOver" method="post"><input type="hidden" name="year" value="@Model.Year" /><input type="hidden" name="month" value="@Model.Month" /><details open><summary><input type="checkbox" name="sections" value="bills" checked /> Bills</summary><p>Copies this month’s bills to next month.</p></details><details open><summary><input type="checkbox" name="sections" value="investments" checked /> Investments</summary><p>Copies your monthly investment records.</p></details><details><summary><input type="checkbox" name="sections" value="extra_expenses" /> Extra expenses</summary><p>Off by default so one-off spending does not accidentally repeat.</p></details><button class="primary">Carry selected items</button></form></div></div>

<div class="modal" id="accountModal"><div class="modal-panel"><button class="x" data-close>×</button><h2>Goal accounts</h2>@foreach(var a in Model.Accounts){
    <form asp-action="SaveAccount" method="post" class="account-form"><input type="hidden" name="year" value="@Model.Year" /><input type="hidden" name="month" value="@Model.Month" /><input type="hidden" name="id" value="@a.Id" /><label>Name<input name="name" value="@a.Name" @(a.Id == 0 ? "readonly" : "") /></label><label>Amount<input name="amount" type="number" step="0.01" value="@a.Amount" /></label><label class="advanced">Interest %<input name="interestRate" type="number" step="0.01" value="@a.InterestRate" /></label><label class="advanced">Monthly in<input name="monthlyContribution" type="number" step="0.01" value="@a.MonthlyContribution" /></label><label><input name="includeInGlobalGoal" type="checkbox" value="true" checked="@(a.IncludeInGlobalGoal)" /> Include</label><button>Save</button></form>
}
<form asp-action="SaveAccount" method="post" class="account-form"><input type="hidden" name="year" value="@Model.Year" /><input type="hidden" name="month" value="@Model.Month" /><input type="hidden" name="id" value="0" /><input name="name" placeholder="New account name" /><input name="amount" type="number" step="0.01" placeholder="Amount" /><input name="interestRate" type="number" step="0.01" placeholder="Interest %" /><input name="monthlyContribution" type="number" step="0.01" placeholder="Monthly in" /><button>Add</button></form></div></div>
}
