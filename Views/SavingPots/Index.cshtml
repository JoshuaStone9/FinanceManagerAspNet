@model FinanceManagerAspNet.Models.SavingPotsViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Saving Pots";
    var gb = CultureInfo.GetCultureInfo("en-GB");
    var canEdit = User.Identity?.IsAuthenticated == true;
    var monthNames = Enumerable.Range(1, 12).Select(m => new DateTime(Model.Year, m, 1).ToString("MMM")).ToList();
    var currentUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
}

<section class="hero card">
    <div>
        <p class="eyebrow">Saving Pots</p>
        <h1>Monthly pot tracker</h1>
        <p class="muted">Mark each month green when you have saved it. Saved pot money and extras are deducted from your available emergency fund.</p>
    </div>
</section>

<section class="grid cards-4">
    <article class="card">
        <p class="eyebrow">Emergency fund total</p>
        <h2>@Model.EmergencyFundTotal.ToString("C", gb)</h2>
        <p>Original emergency fund amount.</p>
    </article>
    <article class="card">
        <p class="eyebrow">Allocated to pots</p>
        <h2>@Model.AllocatedToPots.ToString("C", gb)</h2>
        <p>Total saved months and one-off extras across all pots.</p>
    </article>
    <article class="card">
        <p class="eyebrow">Available emergency fund</p>
        <h2 class="@(Model.AvailableEmergencyFund >= 0 ? "good" : "bad")">@Model.AvailableEmergencyFund.ToString("C", gb)</h2>
        <p>Emergency fund after pot savings are ring-fenced.</p>
    </article>
    <article class="card">
        <p class="eyebrow">Selected year</p>
        <h2>@Model.Year</h2>
        <form method="get" class="year-form">
            <select name="year" onchange="this.form.submit()">
                @for (var y = DateTime.Today.Year - 2; y <= DateTime.Today.Year + 3; y++)
                {
                    <option value="@y" selected="@(y == Model.Year)">@y</option>
                }
            </select>
        </form>
    </article>
</section>

@if (canEdit)
{
    <section class="card">
        <p class="eyebrow">Add new pot</p>
        <form asp-action="SavePot" method="post" class="planner-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="0" />
            <input type="hidden" name="year" value="@Model.Year" />
            <label>Pot name<input name="name" placeholder="Florida Holiday" required /></label>
            <label>Target amount<input type="number" step="0.01" name="targetAmount" value="0" /></label>
            <label>Monthly amount<input type="number" step="0.01" name="monthlyAmount" value="0" /></label>
            <button class="primary" type="submit">Add pot</button>
        </form>
    </section>
}
else
{
    <section class="card actions">
        <a class="button primary" asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@currentUrl">Login to edit saving pots</a>
    </section>
}

<section class="card table-card">
    <h2>Pots and monthly status</h2>
    <p class="muted">Green means saved. Red means not yet saved. Edit details now sit directly under each pot.</p>

    <div class="pot-list">
        @foreach (var row in Model.Pots)
        {
            <article class="pot-card">
                <div class="pot-header">
                    <div>
                        <p class="eyebrow">Pot</p>
                        <h3>@row.Pot.Name</h3>
                    </div>
                    <div class="pot-totals">
                        <span>Monthly <strong>@row.Pot.MonthlyAmount.ToString("C", gb)</strong></span>
                        <span>Target <strong>@row.Pot.TargetAmount.ToString("C", gb)</strong></span>
                        <span>Saved <strong class="good">@row.SavedBalance.ToString("C", gb)</strong></span>
                        <span>Remaining <strong>@row.Remaining.ToString("C", gb)</strong></span>
                    </div>
                </div>

                <div class="month-grid">
                    @for (var m = 1; m <= 12; m++)
                    {
                        var month = row.Months.FirstOrDefault(x => x.Month == m);
                        var isSaved = month?.IsSaved == true;
                        <div class="month-cell">
                            <span>@monthNames[m - 1]</span>
                            @if (canEdit)
                            {
                                <form asp-action="ToggleMonth" method="post" class="blob-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="potId" value="@row.Pot.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@m" />
                                    <button type="submit" class="status-blob @(isSaved ? "saved" : "missed")" title="@(isSaved ? "Saved" : "Not saved")"></button>
                                </form>
                            }
                            else
                            {
                                <span class="status-blob readonly @(isSaved ? "saved" : "missed")" title="@(isSaved ? "Saved" : "Not saved")"></span>
                            }
                        </div>
                    }
                </div>

                @if (canEdit)
                {
                    <details class="pot-edit" open>
                        <summary>Edit pot details / add extra</summary>
                        <div class="pot-edit-grid">
                            <form asp-action="SavePot" method="post" class="stack-form edit-pot-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.Pot.Id" />
                                <input type="hidden" name="year" value="@Model.Year" />
                                <label>Name<input name="name" value="@row.Pot.Name" required /></label>
                                <label>Target<input type="number" step="0.01" name="targetAmount" value="@row.Pot.TargetAmount" /></label>
                                <label>Monthly<input type="number" step="0.01" name="monthlyAmount" value="@row.Pot.MonthlyAmount" /></label>
                                <button type="submit">Save details</button>
                            </form>

                            <form asp-action="AddExtra" method="post" class="stack-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="potId" value="@row.Pot.Id" />
                                <input type="hidden" name="year" value="@Model.Year" />
                                <label>Extra amount<input type="number" step="0.01" min="0.01" name="amount" placeholder="100.00" required /></label>
                                <label>Date<input type="date" name="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></label>
                                <label>Note<input type="text" name="note" placeholder="Bonus, overtime, spare cash..." /></label>
                                <button type="submit" class="primary">Add extra</button>
                            </form>

                            <form asp-action="DeletePot" method="post" class="stack-form delete-pot-form" onsubmit="return confirm('Delete this saving pot?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.Pot.Id" />
                                <input type="hidden" name="year" value="@Model.Year" />
                                <button type="submit" class="danger">Delete pot</button>
                            </form>
                        </div>
                    </details>
                }
            </article>
        }
    </div>
</section>
